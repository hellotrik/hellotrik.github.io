{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: 本地预览",
      "type": "shell",
      "icon": {
        "id": "play",
        "tooltip": "启动 Jekyll 开发服务器（含 livereload）"
      },
      "command": "jekyll serve --livereload --force_polling",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "/opt/homebrew/opt/ruby/bin:/opt/homebrew/lib/ruby/gems/4.0.0/bin:${env:PATH}",
          "LANG": "en_US.UTF-8",
          "LC_ALL": "en_US.UTF-8"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Configuration file:",
          "endsPattern": "Server running"
        }
      }
    }
  ]
}
